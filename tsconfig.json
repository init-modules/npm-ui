{
	"compilerOptions": {
		"declaration": true,
		"declarationMap": false,
		"emitDeclarationOnly": false,
		"jsx": "react-jsx",
		"lib": ["DOM", "ES2022"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"noEmit": true,
		"strict": true,
		"target": "ES2022",
		"types": ["react", "react-dom"]
	},
	"include": ["src"]
}

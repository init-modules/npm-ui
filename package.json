{
	"name": "@init/ui",
	"version": "0.1.0",
	"description": "Shared shadcn-based UI primitives for init npm packages.",
	"type": "module",
	"files": [
		"dist",
		"src"
	],
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts --clean",
		"storybook": "storybook dev -p 6006 -c .storybook",
		"build-storybook": "storybook build -c .storybook -o storybook-static",
		"test-storybook": "test-storybook --url http://127.0.0.1:6006",
		"prepack": "npm run build"
	},
	"dependencies": {
		"@radix-ui/react-accordion": "^1.2.12",
		"@radix-ui/react-separator": "^1.1.8",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-popover": "^1.1.15",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"gsap": "^3.15.0",
		"lucide-react": "^0.556.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.4.0"
	},
	"peerDependencies": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@storybook/addon-a11y": "^10.1.7",
		"@storybook/react-vite": "^10.1.7",
		"@storybook/test-runner": "^0.24.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"storybook": "^10.3.5",
		"tsup": "^8.5.0",
		"typescript": "^5.9.3"
	}
}
